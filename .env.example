"""
Configuration Example File (.env template)
Copy this to .env and update values
"""

# Environment
FLASK_ENV=production
DEBUG=false

# API Configuration
API_HOST=0.0.0.0
API_PORT=5000
API_DEBUG=false

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Model Paths
MODEL_PATH=model/model_volatility.h5
SCALER_PATH=model/scaler.pkl

# Database (Optional)
DATABASE_URL=postgresql://user:password@localhost:5432/qnn_db

# Security
SECRET_KEY=your-secret-key-here
API_KEY=your-api-key-here

# Deployment
WORKERS=4
TIMEOUT=60
MAX_REQUESTS=1000

# CORS
CORS_ORIGINS=http://localhost:3000,https://example.com

# Monitoring (Optional)
SENTRY_DSN=
DATADOG_API_KEY=

# Batch Processing
BATCH_SIZE=32
MAX_BATCH_SIZE=1000

# Model Inference
VERBOSE=0
PREDICTION_THRESHOLD=0.01
